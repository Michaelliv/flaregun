{
  "name": "@miclivs/flaregun",
  "version": "0.1.1",
  "description": "Rotating proxy network on Cloudflare Workers. Deploy, rotate, fire.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "flaregun": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "bun run src/main.ts",
    "build:bun": "bun build --compile src/main.ts --outfile flaregun",
    "build:bun-linux": "bun build --compile --target=bun-linux-x64 src/main.ts --outfile flaregun-linux-x64",
    "build:bun-mac-arm": "bun build --compile --target=bun-darwin-arm64 src/main.ts --outfile flaregun-darwin-arm64",
    "build:bun-mac-x64": "bun build --compile --target=bun-darwin-x64 src/main.ts --outfile flaregun-darwin-x64",
    "test": "bun test",
    "format": "bunx biome format --write src/",
    "lint": "bunx biome lint src/",
    "check": "bunx biome check src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michaelliv/flaregun.git"
  },
  "homepage": "https://github.com/Michaelliv/flaregun#readme",
  "bugs": {
    "url": "https://github.com/Michaelliv/flaregun/issues"
  },
  "keywords": [
    "proxy",
    "cloudflare",
    "workers",
    "ip-rotation",
    "scraping",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "nanoid": "^5.1.6"
  }
}
